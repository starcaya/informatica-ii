# Archivos compilados
*.o
*.obj
*.exe
*.out

# Directorios de build
build/
cmake-build-*/

# IDEs
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# ignorar cualquier ejecutable en todo el repo
*
!*/
!*.*

# Archivos marcados explícitamente para no subir
*_NOSUBIR.*

# .vscode al final: la regla "!*/" de arriba re-incluye todos los
# directorios, así que la exclusión de .vscode tiene que venir después
# para que tenga la última palabra.
.vscode/
**/.vscode/
